VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# WorkOS is connected as a Supabase OAuth provider so auth.users UUIDs and RLS stay intact.
# Enable only after configuring WorkOS in Supabase Auth and adding the OAuth callback in WorkOS.
VITE_WORKOS_AUTH_ENABLED=false
VITE_WORKOS_CONNECTION_ID=conn_YOUR_WORKOS_CONNECTION_ID
VITE_WEB_PUSH_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY

# Supabase Edge Function secrets (set with `supabase secrets set`, never expose as VITE_*).
# OPENROUTER_MANAGEMENT_KEY=...
# OPENROUTER_API_KEY=...
# OPENROUTER_MODEL=openrouter/free
# STT_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_STT_MODEL=whisper-large-v3
# STT_TIMEOUT_MS=45000
# STT_MAX_FILE_BYTES=18874368
# STT_PROMPT=Финансовая операция на русском языке. Суммы, тенге, KZT, категории и счета.
# AI_MONITOR_CRON_SECRET=...
# AI_ADMIN_ALERT_EMAILS=admin@example.com
# RESEND_API_KEY=...
# ALERT_FROM_EMAIL=FinTrackApp <alerts@your-domain.example>
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:admin@your-domain.example
# NOTIFICATION_FROM_EMAIL=FinTrackApp <notifications@your-domain.example>
